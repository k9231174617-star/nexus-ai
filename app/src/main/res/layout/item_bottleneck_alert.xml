<?xml version="1.0" encoding="utf-8"?>
<FrameLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:id="@+id/alertCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/alertHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/alertColorIndicator"
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:background="@color/accent_red"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivAlertIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_alert_critical"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAlertTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High Latency Detected"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvAlertSeverity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CRITICAL"
                        android:textColor="@color/accent_red"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAlertTimestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2m ago"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="12dp" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivExpandAlert"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand"
                android:tint="@color/text_secondary" />
        </LinearLayout>

        <!-- Details -->
        <LinearLayout
            android:id="@+id/layoutAlertDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvAlertDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Request latency exceeds threshold of 500ms"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAlertMetric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="latency: 1250.50 ms"
                android:textColor="@color/accent_orange"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECOMMENDATIONS"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvAlertRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Check database connection pool\n• Review query optimization"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AFFECTED TRACES"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvAlertAffectedTraces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="trace-123\ntrace-456"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnInvestigate"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="INVESTIGATE"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_blue"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnIgnoreAlert"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="IGNORE"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnResolveAlert"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="RESOLVE"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_green"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Resolved Overlay -->
    <FrameLayout
        android:id="@+id/alertResolvedOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA0A1929"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResolvedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="RESOLVED"
            android:textColor="@color/accent_green"
            android:textSize="24sp"
            android:textStyle="bold"
            android:rotation="-15" />
    </FrameLayout>

</FrameLayout>
