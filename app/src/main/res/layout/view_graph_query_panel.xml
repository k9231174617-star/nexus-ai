<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_card_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etGraphQuery"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Cypher query: MATCH (n) RETURN n"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/bg_input_dark"
            android:paddingHorizontal="16dp"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/btnClearQuery"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnQueryHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_cyan" />

        <Button
            android:id="@+id/btnExecuteQuery"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="RUN"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/accent_green"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSampleQueries"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Sample Queries"
        android:textColor="@color/accent_cyan"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <ProgressBar
        android:id="@+id/queryProgressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvQueryStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:id="@+id/scrollQueryResults"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_dark"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvQueryResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Results will appear here..."
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2" />
    </ScrollView>

</LinearLayout>
