<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Regular 400 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/inter_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <!-- Italic 400 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="400"
        android:font="@font/inter_italic"
        app:fontStyle="italic"
        app:fontWeight="400" />

    <!-- Medium 500 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="500"
        android:font="@font/inter_medium"
        app:fontStyle="normal"
        app:fontWeight="500" />

    <!-- Medium Italic 500 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="500"
        android:font="@font/inter_medium_italic"
        app:fontStyle="italic"
        app:fontWeight="500" />

    <!-- SemiBold 600 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="600"
        android:font="@font/inter_semibold"
        app:fontStyle="normal"
        app:fontWeight="600" />

    <!-- SemiBold Italic 600 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="600"
        android:font="@font/inter_semibold_italic"
        app:fontStyle="italic"
        app:fontWeight="600" />

    <!-- Bold 700 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/inter_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />

    <!-- Bold Italic 700 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="700"
        android:font="@font/inter_bold_italic"
        app:fontStyle="italic"
        app:fontWeight="700" />

    <!-- ExtraBold 800 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="800"
        android:font="@font/inter_extrabold"
        app:fontStyle="normal"
        app:fontWeight="800" />

    <!-- ExtraBold Italic 800 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="800"
        android:font="@font/inter_extrabold_italic"
        app:fontStyle="italic"
        app:fontWeight="800" />

    <!-- Black 900 -->
    <font
        android:fontStyle="normal"
        android:fontWeight="900"
        android:font="@font/inter_black"
        app:fontStyle="normal"
        app:fontWeight="900" />

    <!-- Black Italic 900 -->
    <font
        android:fontStyle="italic"
        android:fontWeight="900"
        android:font="@font/inter_black_italic"
        app:fontStyle="italic"
        app:fontWeight="900" />

</font-family>
