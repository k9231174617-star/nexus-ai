<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/statsBarCard"
    android:layout_width="match_parent"
    android:layout_height="36dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="0dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/neon_cyan_alpha">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/dotLLM"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_online" />

            <TextView
                android:id="@+id/tvLLMStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="GPT-4"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/divider_dark" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_token"
                android:tint="@color/neon_green" />

            <TextView
                android:id="@+id/tvTokenCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="4.2K / 8K"
                android:textColor="@color/neon_green"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/divider_dark" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_speed"
                android:tint="@color/neon_purple" />

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="245ms"
                android:textColor="@color/neon_purple"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/divider_dark" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_memory"
                android:tint="@color/neon_pink" />

            <TextView
                android:id="@+id/tvMemoryUsage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="128 MB"
                android:textColor="@color/neon_pink"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <com.nexus.agent.ui.cli.RootBadgeView
            android:id="@+id/rootBadge"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvCacheStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CACHE"
            android:textColor="@color/neon_orange"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_neon_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
