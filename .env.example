# ============================================================
# NEXUS AI — Environment Variables
# Copy to .env for local dev, set in Railway Dashboard for prod
# ============================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default LLM Model (OpenRouter model ID)
LLM_MODEL=openai/gpt-4o-mini

# Your Railway deployment URL (for Telegram Mini App)
WEB_DASHBOARD_URL=https://your-project.up.railway.app

# Server port (Railway sets this automatically)
PORT=8080

# Optional: Restrict bot to specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
ALLOWED_USERS=
