<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/etEntityName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Entity name"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@drawable/bg_input_dark"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <AutoCompleteTextView
        android:id="@+id/actvEntityType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Type (person, organization, concept...)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@drawable/bg_input_dark"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etEntityProperties"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Properties (key=value per line)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@drawable/bg_input_dark"
        android:padding="16dp"
        android:textSize="14sp"
        android:gravity="top"
        android:inputType="textMultiLine" />

</LinearLayout>
