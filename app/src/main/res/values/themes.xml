<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NexusAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Status/Nav bar -->
        <item name="android:statusBarColor">@color/bg_sidebar</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Material colors -->
        <item name="colorPrimary">@color/red_core</item>
        <item name="colorPrimaryDark">@color/red_dim</item>
        <item name="colorAccent">@color/red_bright</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorBackground">@color/bg_deep</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Text appearance -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/red_glow_soft</item>
        <item name="colorControlHighlight">@color/red_glow_soft</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:colorEdgeEffect">@color/red_core</item>
    </style>

    <!-- Neon Card style -->
    <style name="Widget.NexusAI.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">10dp</item>
    </style>

    <!-- Input style -->
    <style name="Widget.NexusAI.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/red_core</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Button style -->
    <style name="Widget.NexusAI.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_core</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">10dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Outline Button -->
    <style name="Widget.NexusAI.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_mid</item>
        <item name="android:textColor">@color/red_bright</item>
        <item name="cornerRadius">10dp</item>
        <item name="rippleColor">@color/red_glow_soft</item>
    </style>
</resources>