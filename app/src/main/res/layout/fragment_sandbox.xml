<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.nexus.agent.ui.sandbox.LanguageSelector
        android:id="@+id/languageSelector"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        app:layout_constraintTop_toBottomOf="@id/languageSelector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.nexus.agent.ui.sandbox.CodeEditorPanel
        android:id="@+id/codeEditor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/editorToolbar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_dark"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_undo"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_redo"
            android:tint="@color/text_secondary" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="@color/divider_dark" />

        <ImageButton
            android:id="@+id/btnFormat"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_format"
            android:tint="@color/neon_cyan" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            android:tint="@color/neon_green" />

    </LinearLayout>

    <View
        android:id="@+id/dividerBottom"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/runBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.nexus.agent.ui.sandbox.OutputConsole
            android:id="@+id/outputConsole"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="@color/terminal_bg" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider_dark" />

        <com.nexus.agent.ui.sandbox.ResourceMonitorView
            android:id="@+id/resourceMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/surface_dark" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/runBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_dark"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRun"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Run"
            android:textColor="@color/background_dark"
            app:backgroundTint="@color/neon_green"
            app:icon="@drawable/ic_play"
            app:iconTint="@color/background_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDebug"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Debug"
            android:textColor="@color/neon_orange"
            app:strokeColor="@color/neon_orange"
            app:icon="@drawable/ic_bug"
            app:iconTint="@color/neon_orange" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvExecutionTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0ms"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/neon_cyan"
            app:indicatorSize="24dp"
            app:trackThickness="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
