<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFile"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivFileIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_file"
                android:tint="@color/neon_cyan" />

            <com.nexus.agent.ui.common.NeonToggleView
                android:id="@+id/checkboxSelect"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivFolderIndicator"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_folder_open"
                android:tint="@color/neon_green"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="filename.txt"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="middle"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvFileMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="2.4 KB • 12.07.2026"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvRootIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"
            android:text="ROOT"
            android:textColor="@color/neon_orange"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_neon_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
