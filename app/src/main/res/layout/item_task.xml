<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/task_priority_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:layout_marginBottom="8dp"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/task_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/neon_white"
        android:fontFamily="sans-serif-medium"
        android:ellipsize="end"
        android:maxLines="2" />

    <TextView
        android:id="@+id/task_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/neon_gray"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.nexus.agent.ui.common.NeonToggleView
            android:id="@+id/task_status_indicator"
            android:layout_width="24dp"
            android:layout_height="24dp" />

        <TextView
            android:id="@+id/task_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-mono" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/task_subtask_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/neon_gray"
            android:fontFamily="sans-serif-mono" />
    </LinearLayout>
</merge>
