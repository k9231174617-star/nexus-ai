<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardChunk"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChunkId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#42"
                android:textColor="@color/neon_cyan"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_neon_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tvSourceDoc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="document.pdf"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="middle" />

            <TextView
                android:id="@+id/tvSimilarity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.94"
                android:textColor="@color/neon_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/divider_dark" />

        <TextView
            android:id="@+id/tvChunkText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua..."
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="5"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvChunkRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="chars 1024-2048"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTokenCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="256 tokens"
                android:textColor="@color/neon_purple"
                android:textSize="10sp"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
